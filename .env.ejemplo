# ============================================================
#  CHATBOT-AI — Variables de Entorno de Ejemplo
#  Copia este archivo como .env y completa los valores reales.
#  ⚠️  NUNCA subas el archivo .env real al repositorio.
# ============================================================

# -----------------------------------------------------------
# 🔑 BACKEND — wizybot-api
# -----------------------------------------------------------

# OpenAI API Key
# Obtenla en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Open Exchange Rates App ID (conversión de divisas)
# Obtenlo en: https://openexchangerates.org/account/app-ids
OPEN_EXCHANGE_APP_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------
# 🌐 FRONTEND — wizybot-frontend
# (Solo necesario si usas Docker o producción)
# -----------------------------------------------------------

# URL base del backend (sin barra final)
# Desarrollo local: http://localhost:3100
# Producción:       http://TU_IP_O_DOMINIO:3100
VITE_API_URL=http://localhost:3100
